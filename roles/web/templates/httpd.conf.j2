5. web Role

Responsibilities
Install Apache + PHP
Deploy WordPress
Deploy MediaWiki
Configure virtual hosts
Configure SELinux contexts


====================================
tasks
====================================

---
#
# INSTALL PACKAGES
#

- name: Install Apache and PHP packages
  ansible.builtin.dnf:
    name: "{{ web_packages }}"
    state: present

#
# ENABLE HTTPD
#

- name: Ensure Apache is enabled and running
  ansible.builtin.service:
    name: "{{ apache_service }}"
    enabled: true
    state: started

#
# CREATE WEB DIRECTORIES
#

- name: Create web application directories
    loop:
    - "{{ wordpress_dir }}"
    - "{{ mediawiki_dir }}"
  ansible.builtin.file:
    path: "{{ item }}"
    state: directory
    owner: apache
    group: apache
    mode: '0755'


#
# DOWNLOAD WORDPRESS
#

- name: Download WordPress
  ansible.builtin.unarchive:
    src: https://wordpress.org/latest.tar.gz
    dest: /var/www/
    remote_src: true
    creates: "{{ wordpress_dir }}/index.php"

#
# DOWNLOAD MEDIAWIKI
#

- name: Download MediaWiki
  ansible.builtin.unarchive:
    src: https://releases.wikimedia.org/mediawiki/1.41/mediawiki-1.41.1.tar.gz
    dest: {{ mediawiki_dir }}
    remote_src: true
    extra_opts: [--strip-components=1]
    creates: "{{ mediawiki_dir }}/index.php"

#
# WORDPRESS CONFIG
#

- name: Deploy wp-config.php
  ansible.builtin.template:
    src: wp-config.php.j2
    dest: "{{ wordpress_dir }}/wp-config.php"
    owner: apache
    group: apache
    mode: '0644'
  notify: restart httpd

#
# APACHE CONFIG
#

- name: Deploy wp-config.php
  ansible.builtin.template:
    src: httpd.conf.j2
    dest: "{{ httpd_dir }}/hardening.conf"
    owner: apache
    group: apache
    mode: '0644'
  notify: restart httpd

#
# MEDIAWIKI CONFIG
#

- name: Deploy LocalSettings.php
  ansible.builtin.template:
    src: LocalSettings.php.j2
    dest: "{{ mediawiki_dir }}/LocalSettings.php"
    owner: apache
    group: apache
    mode: '0644'
  notify: restart httpd

#
# APACHE VHOSTS
#

- name: Deploy WordPress vhost
  ansible.builtin.template:
    src: wordpress.conf.j2
    dest: /etc/httpd/conf.d/wordpress.conf
    owner: root
    group: root
    mode: '0644'
  notify: restart httpd

- name: Deploy MediaWiki vhost
  ansible.builtin.template:
    src: mediawiki.conf.j2
    dest: /etc/httpd/conf.d/mediawiki.conf
    owner: root
    group: root
    mode: '0644'
  notify: restart httpd

#
# SELINUX CONTEXTS
#

- name: Set SELinux context for WordPress
  ansible.posix.sefcontext:
    target: "{{ wordpress_dir }}(/.*)?"
    setype: httpd_sys_rw_content_t
    state: present

- name: Set SELinux context for MediaWiki
  ansible.posix.sefcontext:
    target: "{{ mediawiki_dir }}(/.*)?"
    setype: httpd_sys_rw_content_t
    state: present

- name: Restore SELinux context for web dirs
  ansible.builtin.command: restorecon -Rv {{ wordpress_dir }} {{ mediawiki_dir }}
  changed_when: false

#
# APACHE CONFIG VALIDATION
#

- name: Validate Apache configuration
  ansible.builtin.command: apachectl configtest
  changed_when: false




=======================================
handlers
=======================================
---
- name: restart httpd
  ansible.builtin.service:
    name: httpd
    state: restarted

