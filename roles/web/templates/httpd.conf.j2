defaults
========================================


================
templates/wordpress.conf.j2
================

<VirtualHost *:80>
    ServerName www.{{ domain_name }}

    DocumentRoot {{ wordpress_dir }}

    <Directory {{ wordpress_dir }}>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog /var/log/httpd/wordpress-error.log
    CustomLog /var/log/httpd/wordpress-access.log combined
</VirtualHost>

================
templates/mediawiki.conf.j2
================

<VirtualHost *:80>
    ServerName wiki.{{ domain_name }}

    DocumentRoot {{ mediawiki_dir }}

    <Directory {{ mediawiki_dir }}>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog /var/log/httpd/mediawiki-error.log
    CustomLog /var/log/httpd/mediawiki-access.log combined
</VirtualHost>

